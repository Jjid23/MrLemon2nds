rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSuperAdmin() { 
      return isSignedIn() && (
        request.auth.token.email in ['jobertyeah23@gmail.com', 'earlperez@gmail.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleId == 'admin')
      ); 
    }
    
    // Identity integrity check
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Dynamic Permission Helper
    function hasPermission(perm) {
      return isSignedIn() && (
        isSuperAdmin() || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          exists(/databases/$(database)/documents/roles/$(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleId)) &&
          perm in get(/databases/$(database)/documents/roles/$(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleId)).data.permissions
        )
      );
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isOwner(userId) || hasPermission('users.manage');
      allow list: if hasPermission('users.manage');
      
      allow create: if isOwner(userId) && (
        // Role safety: Only super admins or those with roles.manage can set roles during creation
        (incoming().roleId == 'staff' || isSuperAdmin() || hasPermission('roles.manage')) &&
        isValidUserShape(incoming()) &&
        incoming().uid == request.auth.uid
      );
      
      allow update: if (isSuperAdmin() || hasPermission('users.manage')) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'roleId'])
      ) || (
        isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name'])
      );
      
      allow delete: if hasPermission('users.manage');
    }

    function isValidUserShape(data) {
      return data.keys().hasAll(['uid', 'email', 'name', 'roleId', 'createdAt']) && 
             data.keys().size() == 5 &&
             data.uid is string && data.uid.size() < 128 &&
             data.email is string && data.email.size() < 256 &&
             data.roleId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 128 &&
             data.createdAt is string;
    }

    // --- Roles ---
    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('roles.manage');
    }

    // --- Inventory ---
    match /inventory/{itemId} {
      allow read: if isSignedIn();
      
      allow create: if hasPermission('inventory.manage') && isValidInventory(incoming()) && isValidId(itemId);
      
      allow update: if (hasPermission('inventory.manage') && isValidInventory(incoming())) || (
        // Action: Order Fulfillment (Stock deduction - orders.create)
        hasPermission('orders.create') && 
        isValidInventory(incoming()) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['quantity', 'updatedAt']) && 
        incoming().quantity < existing().quantity
      );
      
      allow delete: if hasPermission('inventory.manage');
    }

    function isValidInventory(data) {
      return data.keys().hasAll(['name', 'quantity', 'unit', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.quantity is number && data.quantity >= 0 &&
             data.unit is string && data.unit.size() > 0 && data.unit.size() < 24 &&
             (data.updatedAt is string || data.updatedAt is timestamp);
    }

    // --- Orders ---
    match /orders/{orderId} {
      allow read: if isSignedIn() && (hasPermission('orders.read') || resource.data.cashierId == request.auth.uid);
      
      allow create: if hasPermission('orders.create') && 
                    isValidOrder(incoming()) && 
                    incoming().cashierId == request.auth.uid &&
                    isValidId(orderId);
      
      allow update: if hasPermission('reports.view'); // Admins/Managers can edit history
      allow delete: if hasPermission('reports.view');
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['items', 'total', 'subtotal', 'vat', 'paymentMethod', 'cashierId', 'cashierName', 'createdAt']) &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.paymentMethod in ['cash', 'gcash'] &&
             data.cashierId == request.auth.uid &&
             data.cashierName is string &&
             (data.createdAt is string || data.createdAt is timestamp);
     }

     // --- Settings ---
     match /settings/{settingId} {
       allow read: if isSignedIn();
       allow write: if hasPermission('inventory.manage') && isValidSetting(incoming());
     }

     function isValidSetting(data) {
       return data.keys().hasAll(['prices']) &&
              data.prices is map;
     }
   }
 }
